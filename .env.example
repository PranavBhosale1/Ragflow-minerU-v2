# ============================================================================
# .env.example — template for Ragflow-minerU-v2
#
# How to use:
#   cp .env.example ragflow/docker/.env
#   $EDITOR ragflow/docker/.env
#
# The top-level docker-compose.yml reads this file via:
#   docker compose --env-file ragflow/docker/.env up -d
# (see docker-compose.yml line 3).
#
# Every variable here is also documented in:
#   handover_pack/04_SETUP_GUIDE.md §2
#   ragflow/docker/README.md (upstream, for all upstream vars)
# ============================================================================


# ----------------------------------------------------------------------------
# 1. COMPOSE PROFILES — pick ONE doc engine + ONE runtime
# ----------------------------------------------------------------------------
# Accepted tokens (from ragflow/docker/docker-compose-base.yml):
#   doc engine:  elasticsearch | infinity | opensearch | oceanbase | seekdb
#   runtime:     cpu | gpu
#   extras:      tei-cpu | tei-gpu | kibana | sandbox-executor-manager
#
# Typical CPU dev setup:
COMPOSE_PROFILES=elasticsearch,cpu
# Typical GPU setup:
#COMPOSE_PROFILES=elasticsearch,gpu
# Faster embedder on CPU:
#COMPOSE_PROFILES=elasticsearch,cpu,tei-cpu


# ----------------------------------------------------------------------------
# 2. Document / search engine
# ----------------------------------------------------------------------------
DOC_ENGINE=elasticsearch
STACK_VERSION=8.11.3
ES_PORT=1200
ELASTIC_PASSWORD=CHANGE-ME-elastic-password

# If you switch DOC_ENGINE=infinity, see ragflow/docker/README.md for
# Infinity-specific variables.


# ----------------------------------------------------------------------------
# 3. MySQL
# ----------------------------------------------------------------------------
MYSQL_PASSWORD=CHANGE-ME-mysql-password
MYSQL_PORT=3306
EXPOSE_MYSQL_PORT=5455


# ----------------------------------------------------------------------------
# 4. MinIO (S3-compatible object store)
# ----------------------------------------------------------------------------
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_USER=admin
MINIO_PASSWORD=CHANGE-ME-minio-password

# Optional single-bucket mode (see ragflow/docker/.env.single-bucket-example):
#MINIO_BUCKET=ragflow-bucket
#MINIO_PREFIX_PATH=ragflow


# ----------------------------------------------------------------------------
# 5. Redis
# ----------------------------------------------------------------------------
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE-ME-redis-password


# ----------------------------------------------------------------------------
# 6. RAGFlow app image and ports
# ----------------------------------------------------------------------------
RAGFLOW_IMAGE=infiniflow/ragflow:v0.24.0
SVR_WEB_HTTP_PORT=80
SVR_WEB_HTTPS_PORT=443
SVR_HTTP_PORT=9380
ADMIN_SVR_HTTP_PORT=9381
SVR_MCP_PORT=9382
GO_HTTP_PORT=9384
GO_ADMIN_PORT=9383
MEM_LIMIT=8073741824
TZ=UTC


# ----------------------------------------------------------------------------
# 7. MinerU API (set automatically by the top-level compose, but tunable)
# ----------------------------------------------------------------------------
# Host port that maps to container's :8000 (docker-compose.yml line 32).
MINERU_PORT=8000

# The two variables below are set inside docker-compose.yml for the
# RAGFlow services. You rarely need to override them, but listed for
# completeness:
#MINERU_APISERVER=http://mineru-api:8000
#MINERU_MODEL_SOURCE=local


# ----------------------------------------------------------------------------
# 8. Flowchart-on-upload hook (CUSTOM feature)
# ----------------------------------------------------------------------------
# Turn the feature on/off. When true, a PDF upload whose filename
# contains FLOWCHART_NAME_SUBSTRING triggers the flowchart CLI and
# attaches .mmd / _rag.md / _graph.json companions to the same KB.
FLOWCHART_ON_UPLOAD=true

# Where the flowchart CLI is mounted inside the RAGFlow container.
# docker-compose.yml bind-mounts ./flowchart → /flowchart-tools:ro.
FLOWCHART_ROOT=/flowchart-tools

# Filename substring that activates the hook (case-sensitive).
FLOWCHART_NAME_SUBSTRING=flowchart

# Path to Poppler's `bin` directory inside the container.
# For Debian/Ubuntu RAGFlow images (after apt-get install poppler-utils):
FLOWCHART_POPPLER_PATH=/usr/bin

# Subprocess timeout in seconds. First run is slow because EasyOCR
# downloads its English model lazily; keep high for first boot.
FLOWCHART_SUBPROCESS_TIMEOUT=900

# true (default): also upload *.mmd and *_graph.json as companions.
# false: upload only *_rag.md (fastest).
FLOWCHART_UPLOAD_EXTRAS=true


# ----------------------------------------------------------------------------
# 9. Optional: host-side batch uploader (flowchart/ragflow_ingest.py)
# ----------------------------------------------------------------------------
# Used when running ragflow_ingest.py from your workstation, not the
# RAGFlow container. Do NOT put real API keys in a committed .env.
#
#RAGFLOW_BASE_URL=http://127.0.0.1:9380
#RAGFLOW_API_KEY=ragflow-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#RAGFLOW_DATASET_ID=<uuid-from-RAGFlow-UI>
#POPPLER_PATH=/usr/bin   # or the Windows Poppler bin folder


# ----------------------------------------------------------------------------
# 10. Notes
# ----------------------------------------------------------------------------
# - All *_PASSWORD values above are placeholders. Replace before first boot.
# - For HTTPS / reverse proxy, see ragflow/docker/nginx/.
# - For MinIO single-bucket mode, see ragflow/docker/.env.single-bucket-example.
# - For GPU MinerU, use docker-compose.mineru-gpu.yml overlay (no new env vars).
